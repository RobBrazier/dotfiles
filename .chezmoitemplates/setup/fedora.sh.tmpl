echo "Installing packages for Fedora"

install_packages() {
    sudo dnf -y install $@
}

sudo dnf update -y

# System Utilities
install_packages {{ .packages | join " " }} btop util-linux-user perl-File-Compare openssl-devel gcc g++

copr_repos=(lihaohong/yazi scottames/ghostty)
for repo in "${copr_repos[@]}"; do
    if ! dnf copr list | grep -qF "$repo"; then
        sudo dnf copr enable "$repo"
    fi
done

# GUI applications
install_packages ghostty yazi

sudo dnf remove -y wezterm || true
sudo dnf copr remove copr.fedorainfracloud.org/wezfurlong/wezterm-nightly -y || true

