echo "Installing packages for Fedora"

install_packages() {
    sudo dnf -y install $@
}

sudo dnf update -y

# System Utilities
install_packages {{ .packages | join " " }} btop util-linux-user perl-File-Compare openssl-devel gcc g++

copr_repos=(wezfurlong/wezterm-nightly lihaohong/yazi scottames/ghostty)
for repo in "${copr_repos[@]}"; do
    if dnf copr list | grep -qv "$repo"; then
        sudo dnf copr enable "$repo"
    fi
done

# GUI applications
install_packages firefox wezterm ghostty yazi

